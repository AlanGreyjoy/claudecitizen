generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String?              @unique
  username            String               @unique
  displayName         String
  passwordHash        String?
  discordId           String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  player              Player?
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
}

model Player {
  id                String   @id @default(cuid())
  userId            String   @unique
  handle            String   @unique
  displayName       String
  currentInstanceId String
  currentRoomId     String   @default("hab-room")
  assignedHangar    Int?
  arcBalance        Int      @default(0)
  starterLoadoutGrantedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ships             Ship[]
  props             PlayerProp[]
  items             PlayerItem[]
  hangarPlacements  HangarPlacement[]
}

model Ship {
  id                String   @id @default(cuid())
  playerId          String
  shipDefinitionId  String?
  prefabId          String
  displayName       String
  currentInstanceId String?
  hp                Float    @default(1000)
  shields           Float    @default(500)
  maxHp             Float    @default(1000)
  maxShields        Float    @default(500)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  shipDefinition    ShipDefinition? @relation(fields: [shipDefinitionId], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@index([shipDefinitionId])
}

model ShipDefinition {
  id                 String   @id @default(cuid())
  name               String
  description        String
  prefabId           String
  costArc            Int
  maxHp              Float
  maxShields         Float
  shieldRegenPerSec  Float
  maxSpeedMps        Float
  throttleAccelMps2  Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  ships              Ship[]
}

model GameSettings {
  id                       String   @id @default("singleton")
  startingArcBalance       Int      @default(0)
  starterShipDefinitionIds String[] @default([])
  starterPropDefinitionIds String[] @default([])
  starterItemDefinitionIds String[] @default([])
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model PropDefinition {
  id             String   @id @default(cuid())
  name           String
  description    String
  prefabId       String
  costArc        Int
  category       String   @default("decoration")
  maxPerHangar   Int?
  allowRotateY   Boolean  @default(true)
  snapGridM      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  inventory      PlayerProp[]
  placements     HangarPlacement[]
}

model PlayerProp {
  id               String         @id @default(cuid())
  playerId         String
  propDefinitionId String
  quantity         Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  player           Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  propDefinition   PropDefinition @relation(fields: [propDefinitionId], references: [id], onDelete: Cascade)

  @@unique([playerId, propDefinitionId])
  @@index([playerId])
  @@index([propDefinitionId])
}

model ItemDefinition {
  id          String       @id @default(cuid())
  name        String
  description String
  itemType    String
  subType     String       @default("generic")
  prefabId    String?
  iconUrl     String?
  stackMax    Int          @default(99)
  costArc     Int          @default(0)
  rarity      String       @default("common")
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inventory   PlayerItem[]
}

model PlayerItem {
  id               String         @id @default(cuid())
  playerId         String
  itemDefinitionId String
  quantity         Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  player           Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@unique([playerId, itemDefinitionId])
  @@index([playerId])
  @@index([itemDefinitionId])
}

model HangarPlacement {
  id               String         @id @default(cuid())
  playerId         String
  propDefinitionId String
  area             String         @default("hangar")
  right            Float
  up               Float
  forward          Float
  rotationY        Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  player           Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  propDefinition   PropDefinition @relation(fields: [propDefinitionId], references: [id], onDelete: Restrict)

  @@index([playerId])
  @@index([playerId, area])
  @@index([propDefinitionId])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  familyId          String
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
