    "@nestjs/platform-ws": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pino-http": "^11.0.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/node": "^26.0.1",
