{
  "name": "claudecitizen",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:wasm": "node scripts/build_wasm.mjs",
    "build:web": "npm run build:wasm && tsc --noEmit && vite build",
    "build:desktop": "npm run build:web && electron-builder --projectDir desktop --dir",
    "build:server": "cargo build --locked --release -p cc-server",
    "build:protected": "npm run build",
    "deploy:netlify": "npm run build && npx --yes netlify-cli deploy --no-build --dir=dist",
    "deploy:netlify:prod": "npm run build && npx --yes netlify-cli deploy --no-build --prod --dir=dist",
    "deploy:netlify:protected": "npm run deploy:netlify",
    "deploy:netlify:protected:prod": "npm run deploy:netlify:prod",
    "dev": "npm run build:wasm && vite --host 0.0.0.0 --port 4173",
    "desktop": "npm run build:web && electron desktop",
    "desktop:dev": "electron desktop --dev-url=http://127.0.0.1:4173",
    "desktop:package": "npm run build:web && electron-builder --projectDir desktop",
    "dev:infra": "docker compose up -d postgres redis mailpit",
    "dev:server": "watchexec --restart --stop-timeout 20s --no-vcs-ignore --watch backend --watch proto --watch Cargo.toml --watch Cargo.lock --watch rust-toolchain.toml -- cargo run --locked -p cc-server",
    "dev:web": "vite --host 0.0.0.0 --port 4173",
    "demo": "tsx scripts/spike-demo.ts",
    "backend:migrate": "cargo run --locked -p cc-server -- migrate",
    "serve": "vite --host 0.0.0.0 --port 4173",
    "start:server": "cargo run --locked -p cc-server",
    "typecheck": "tsc --noEmit",
    "terrain:validate": "tsx scripts/validate_terrain_system.ts",
    "bake:spawn-tiles": "tsx scripts/bake_spawn_tiles.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:sidekick": "tsx --test test/sidekick_creator.test.ts",
    "docs:dev": "npm run start -w docs",
    "docs:build": "npm run build -w docs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@takram/three-atmosphere": "^0.19.1",
    "@takram/three-clouds": "^0.7.6",
    "@takram/three-geospatial": "^0.9.1",
    "lucide": "^1.25.0",
    "n8ao": "^2.0.0",
    "postprocessing": "^6.39.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "simplex-noise": "^4.0.3",
    "three": "^0.180.0",
    "three-mesh-bvh": "^0.9.0",
    "vite": "^8.1.2"
  }
}
