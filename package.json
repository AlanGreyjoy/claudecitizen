{
  "name": "claudecitizen",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "docs"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:web": "tsc --noEmit && vite build",
    "build:server": "npm run build -w server",
    "build:protected": "npm run build",
    "deploy:netlify": "npm run build && npx --yes netlify-cli deploy --no-build --dir=dist",
    "deploy:netlify:prod": "npm run build && npx --yes netlify-cli deploy --no-build --prod --dir=dist",
    "deploy:netlify:protected": "npm run deploy:netlify",
    "deploy:netlify:protected:prod": "npm run deploy:netlify:prod",
    "dev": "vite --host 0.0.0.0 --port 4173",
    "dev:infra": "docker compose up -d postgres redis mailpit",
    "dev:server": "npm run start:dev -w server",
    "dev:web": "vite --host 0.0.0.0 --port 4173",
    "demo": "tsx scripts/spike-demo.ts",
    "prisma:deploy": "npm run prisma:deploy -w server",
    "prisma:generate": "npm run prisma:generate -w server",
    "prisma:migrate": "npm run prisma:migrate -w server",
    "serve": "vite --host 0.0.0.0 --port 4173",
    "typecheck": "tsc --noEmit && npm run typecheck -w server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:sidekick": "tsx --test test/sidekick_creator.test.ts",
    "docs:dev": "npm run start -w docs",
    "docs:build": "npm run build -w docs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@takram/three-atmosphere": "^0.19.1",
    "@takram/three-clouds": "^0.7.6",
    "@takram/three-geospatial": "^0.9.1",
    "n8ao": "^1.10.3",
    "postprocessing": "^6.39.2",
    "simplex-noise": "^4.0.3",
    "three": "^0.185.1",
    "three-mesh-bvh": "^0.9.0",
    "vite": "^8.1.2"
  }
}
