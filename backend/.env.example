APP_ENV=development
RUST_LOG=cc_server=debug,tower_http=info
HTTP_BIND=0.0.0.0:3000
CLIENT_ORIGIN=http://localhost:4173
API_PUBLIC_URL=http://localhost:3000
DATABASE_URL=postgresql://claude:citizen@localhost:5432/claude_citizen
REDIS_URL=redis://localhost:6379
RUN_MIGRATIONS=true

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ADMIN_EMAIL=admin@claude-citizen.com
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=dev-admin-secret-change-me
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ClaudeCitizen <noreply@localhost>

WEBTRANSPORT_BIND=0.0.0.0:4433
WEBTRANSPORT_PUBLIC_URL=https://localhost:4433/world
# Production uses a mounted PEM certificate/key. When omitted in development,
# the server creates a browser-compatible short-lived self-signed certificate.
WEBTRANSPORT_CERT_PATH=
WEBTRANSPORT_KEY_PATH=

